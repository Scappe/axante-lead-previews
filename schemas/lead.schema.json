{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Axante lead preview",
  "type": "object",
  "required": [
    "slug",
    "companyName",
    "sector",
    "city",
    "website",
    "template",
    "theme",
    "hero",
    "problems",
    "opportunities",
    "services",
    "cta"
  ],
  "properties": {
    "slug": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*-[a-z0-9]{4}$"
    },
    "companyName": { "type": "string", "minLength": 2 },
    "sector": { "type": "string", "minLength": 2 },
    "city": { "type": "string", "minLength": 2 },
    "website": { "type": "string", "format": "uri" },
    "template": {
      "type": "string",
      "enum": ["professional", "local-service", "premium-retail"]
    },
    "heroImage": {
      "type": "string",
      "pattern": "^/leads/[a-z0-9-]+/[a-zA-Z0-9._-]+$"
    },
    "theme": {
      "type": "object",
      "required": ["accent", "accentSecondary", "background"],
      "properties": {
        "accent": { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" },
        "accentSecondary": { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" },
        "background": { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" }
      },
      "additionalProperties": false
    },
    "hero": {
      "type": "object",
      "required": ["eyebrow", "title", "description"],
      "properties": {
        "eyebrow": { "type": "string", "minLength": 3 },
        "title": { "type": "string", "minLength": 8 },
        "description": { "type": "string", "minLength": 30 }
      },
      "additionalProperties": false
    },
    "proposalTitle": { "type": "string", "minLength": 8 },
    "proposalDescription": { "type": "string", "minLength": 30 },
    "problems": {
      "type": "array",
      "minItems": 3,
      "items": { "type": "string", "minLength": 12 }
    },
    "opportunities": {
      "type": "array",
      "minItems": 3,
      "items": { "type": "string", "minLength": 12 }
    },
    "services": {
      "type": "array",
      "minItems": 3,
      "items": {
        "type": "object",
        "required": ["title", "description"],
        "properties": {
          "title": { "type": "string", "minLength": 3 },
          "description": { "type": "string", "minLength": 20 }
        },
        "additionalProperties": false
      }
    },
    "cta": {
      "type": "object",
      "required": ["title", "description", "email"],
      "properties": {
        "title": { "type": "string", "minLength": 5 },
        "description": { "type": "string", "minLength": 20 },
        "email": { "type": "string", "format": "email" }
      },
      "additionalProperties": false
    },
    "verifiedFacts": {
      "type": "array",
      "items": { "type": "string" }
    },
    "sourceUrls": {
      "type": "array",
      "items": { "type": "string", "format": "uri" }
    }
  },
  "additionalProperties": false
}
